<UserControl
    x:Class="D4Loot.App.Views.IssuesPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:D4Loot.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="120" d:DesignWidth="500">

    <UserControl.Resources>
        <conv:ValidationSeverityGlyphConverter x:Key="SeverityGlyph" />
        <conv:ValidationSeverityBrushConverter x:Key="SeverityBrush" />
    </UserControl.Resources>

    <Border BorderThickness="0,1,0,0" BorderBrush="#FFCCCCCC" Padding="4">
        <ItemsControl ItemsSource="{Binding Issues, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <ItemsControl.Template>
                <ControlTemplate TargetType="ItemsControl">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="160">
                        <ItemsPresenter />
                    </ScrollViewer>
                </ControlTemplate>
            </ItemsControl.Template>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="2,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Text="{Binding Severity, Converter={StaticResource SeverityGlyph}}"
                            Foreground="{Binding Severity, Converter={StaticResource SeverityBrush}}"
                            FontWeight="Bold"
                            Width="18"
                            TextAlignment="Center"
                            VerticalAlignment="Top" />
                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding Message}"
                            TextWrapping="Wrap"
                            VerticalAlignment="Top" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</UserControl>
