<Application
    x:Class="ThunderEagle.FilterForge.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:ThunderEagle.FilterForge.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Views/ConditionTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:ConditionTypeNameConverter x:Key="ConditionTypeNameConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
