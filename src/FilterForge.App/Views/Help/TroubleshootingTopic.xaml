<UserControl
    x:Class="ThunderEagle.FilterForge.App.Views.Help.TroubleshootingTopic"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d">

    <FlowDocumentScrollViewer>
        <FlowDocument FontFamily="Segoe UI" FontSize="13" PagePadding="20,16">

            <Paragraph FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12">
                Troubleshooting
            </Paragraph>

            <Paragraph FontSize="14" FontWeight="SemiBold" Margin="0,4,0,6">
                Pasted share code fails to decode or produces unexpected rules
            </Paragraph>

            <Paragraph>
                Share codes copied from community sites or older tools may have subtle encoding
                differences from the current game version. <Bold>Re-export your filter directly from
                the D4 in-game UI</Bold> — open the Loot Filter screen, select your filter, and tap
                <Bold>Share → Copy Code</Bold> — then paste that fresh code into FilterForge.
            </Paragraph>

            <Paragraph FontSize="14" FontWeight="SemiBold" Margin="0,12,0,6">
                Copy Code is disabled
            </Paragraph>

            <Paragraph>
                Diablo IV enforces a hard limit of <Bold>25 rules per filter</Bold>. If your filter
                exceeds this, <Bold>Copy Code</Bold> is disabled until you remove rules. Click
                <Bold>Validate</Bold> to see exactly which rules are flagged.
            </Paragraph>

            <Paragraph FontSize="14" FontWeight="SemiBold" Margin="0,12,0,6">
                AI assistant is not responding
            </Paragraph>

            <Paragraph>
                Verify Ollama is running by opening a terminal and running
                <Run FontFamily="Consolas">ollama list</Run>.
                Confirm the <Bold>Base URL</Bold> in the AI panel matches your Ollama port —
                the default is <Run FontFamily="Consolas">http://localhost:11434</Run>.
            </Paragraph>

            <Paragraph FontSize="14" FontWeight="SemiBold" Margin="0,12,0,6">
                AI assistant generates incorrect or malformed rules
            </Paragraph>

            <Paragraph>
                Non-coding general-purpose models (e.g. <Run FontFamily="Consolas">llama3.2</Run>)
                produce poor results with FilterForge's structured JSON output. Switch to a
                <Run FontFamily="Consolas">qwen2.5-coder</Run> model — see
                <Bold>AI Assistant Setup</Bold> for model recommendations.
                Always review generated rules before adding them to your filter.
            </Paragraph>

        </FlowDocument>
    </FlowDocumentScrollViewer>

</UserControl>
