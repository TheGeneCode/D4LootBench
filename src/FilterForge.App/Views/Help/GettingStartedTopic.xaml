<UserControl
    x:Class="ThunderEagle.FilterForge.App.Views.Help.GettingStartedTopic"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d">

    <FlowDocumentScrollViewer>
        <FlowDocument FontFamily="Segoe UI" FontSize="13" PagePadding="20,16">

            <Paragraph FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12">
                Getting Started
            </Paragraph>

            <Paragraph>
                FilterForge edits Diablo IV loot filter share codes. The workflow is three steps:
            </Paragraph>

            <List MarkerStyle="Decimal" Margin="8,4,0,12">
                <ListItem>
                    <Paragraph>
                        <Bold>Copy your share code from D4.</Bold>
                        In-game, open the Loot Filter screen, select your filter, and tap
                        <Bold>Share → Copy Code</Bold>.
                    </Paragraph>
                </ListItem>
                <ListItem>
                    <Paragraph>
                        <Bold>Paste and edit in FilterForge.</Bold>
                        Click <Bold>Paste Code</Bold> in the toolbar. Your filter rules will appear in the
                        Visual Editor. Add, remove, or reorder rules; click any rule to edit its conditions,
                        color, and visibility.
                    </Paragraph>
                </ListItem>
                <ListItem>
                    <Paragraph>
                        <Bold>Copy the code back.</Bold>
                        Click <Bold>Copy Code</Bold> in the toolbar. Return to D4, open the Loot Filter
                        screen, and paste the code to import your updated filter.
                    </Paragraph>
                </ListItem>
            </List>

            <Paragraph FontSize="14" FontWeight="SemiBold" Margin="0,8,0,6">
                Opening and saving as JSON
            </Paragraph>

            <Paragraph>
                Use <Bold>Open JSON…</Bold> and <Bold>Save JSON…</Bold> to work with human-readable filter
                files. JSON files preserve all rule data and are useful for backups or sharing filters with
                other FilterForge users.
            </Paragraph>

            <Paragraph FontSize="14" FontWeight="SemiBold" Margin="0,12,0,6">
                Rule limit
            </Paragraph>

            <Paragraph>
                Diablo IV enforces a maximum of <Bold>25 rules per filter</Bold>. FilterForge tracks this
                limit and disables <Bold>Copy Code</Bold> if you exceed it. The Validate button will also
                report the violation.
            </Paragraph>

        </FlowDocument>
    </FlowDocumentScrollViewer>

</UserControl>
