<Window x:Class="D4LootBench.App.Views.ProgressionWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:D4LootBench.App.Converters"
        xmlns:vm="clr-namespace:D4LootBench.App.ViewModels.Progression"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:ProgressionWizardViewModel, IsDesignTimeCreatable=False}"
        Title="Build a Progression Filter"
        Width="720" MinWidth="520"
        Height="560" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <conv:EnumEqualsVisibilityConverter x:Key="StepVis" />

        <!-- Red text when HasError, normal dark text otherwise -->
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasError}" Value="True">
                    <Setter Property="Foreground" Value="#C0392B" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasError}" Value="False">
                    <Setter Property="Foreground"
                            Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">

        <!-- ── Status bar ───────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Padding="0,10,0,0">
            <TextBlock Text="{Binding StatusText}"
                       Style="{StaticResource StatusTextStyle}"
                       TextWrapping="Wrap" />
        </Border>

        <!-- ── Step panels (exactly one visible) ────────────────────── -->
        <Grid>

            <!-- ══ Step 1 · Read Gear ══════════════════════════════════ -->
            <DockPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVis}, ConverterParameter=ReadGear}">
                <TextBlock DockPanel.Dock="Top"
                           Text="Step 1 of 4 — Read your equipped gear"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock DockPanel.Dock="Top"
                           Text="Screenshot a gear tooltip in-game (Win+Shift+S), then paste it here — or open a saved image. Enable Advanced Tooltip Information in D4."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Margin="0,0,0,10" />

                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Paste Screenshot" Click="PasteScreenshot"
                            Height="28" Padding="12,0" Margin="0,0,8,0" />
                    <Button Content="Open Image…" Click="OpenImageFile"
                            Height="28" Padding="12,0" />
                </StackPanel>

                <Button DockPanel.Dock="Bottom"
                        Content="Next: Review ▶"
                        HorizontalAlignment="Right"
                        Height="28" Padding="14,0" Margin="0,10,0,0"
                        Command="{Binding NextToReviewCommand}" />

                <Border BorderThickness="1" Padding="4"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
                    <ListBox ItemsSource="{Binding Items}"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Remove"
                                            Height="24" Padding="8,0"
                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="{Binding ItemTypeName, Mode=OneWay}" FontWeight="SemiBold" />
                                        <Run Text=" — " />
                                        <Run Text="{Binding Slot, Mode=OneWay}" />
                                    </TextBlock>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- ══ Step 2 · Review ═════════════════════════════════════ -->
            <DockPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVis}, ConverterParameter=Review}">
                <TextBlock DockPanel.Dock="Top"
                           Text="Step 2 of 4 — Review &amp; correct"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock DockPanel.Dock="Top"
                           Text="Fix any misread slot, power, rarity, or affix. Tick greater affixes by hand — OCR cannot detect them."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Margin="0,0,0,10" />

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="◀ Back" Height="28" Padding="14,0" Margin="0,0,8,0"
                            Command="{Binding BackToReadCommand}" />
                    <Button Content="Next: Goal ▶" Height="28" Padding="14,0"
                            Command="{Binding NextToGoalCommand}" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,8"
                                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ItemTypeName, Mode=OneWay}"
                                                   FontWeight="SemiBold" Margin="0,0,0,6" />

                                        <!-- Needs-review highlight -->
                                        <TextBlock Text="⚠ Needs review — check the fields below."
                                                   Foreground="#C0392B" Margin="0,0,0,6"
                                                   Visibility="{Binding NeedsReview, Converter={StaticResource StepVis}, ConverterParameter=True}" />

                                        <UniformGrid Columns="4" Margin="0,0,0,6">
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Slot" FontSize="11" />
                                                <ComboBox ItemsSource="{Binding AvailableSlots}"
                                                          SelectedItem="{Binding Slot}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Item Power" FontSize="11" />
                                                <TextBox Text="{Binding ItemPower, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Rarity" FontSize="11" />
                                                <ComboBox ItemsSource="{Binding AvailableRarities}"
                                                          SelectedItem="{Binding Rarity}" />
                                            </StackPanel>
                                            <StackPanel VerticalAlignment="Bottom">
                                                <CheckBox Content="Ancestral" IsChecked="{Binding IsAncestral}" />
                                            </StackPanel>
                                        </UniformGrid>

                                        <TextBlock Text="Affixes" FontSize="11" Margin="0,0,0,2" />
                                        <ItemsControl ItemsSource="{Binding Affixes}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel Margin="0,1">
                                                        <CheckBox DockPanel.Dock="Right" Content="Greater"
                                                                  VerticalAlignment="Center" Margin="8,0,0,0"
                                                                  IsChecked="{Binding IsGreaterAffix}" />
                                                        <TextBlock Text="{Binding RawText, Mode=OneWay}"
                                                                   TextWrapping="Wrap" VerticalAlignment="Center" />
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <ItemsControl ItemsSource="{Binding Warnings}" Margin="0,4,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                                               FontSize="11" Foreground="#B9770E" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <!-- ══ Step 3 · Goal ═══════════════════════════════════════ -->
            <DockPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVis}, ConverterParameter=Goal}">
                <TextBlock DockPanel.Dock="Top"
                           Text="Step 3 of 4 — Paste your goal build"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock DockPanel.Dock="Top"
                           Text="Paste the gear section of a build guide (Mobalytics, Maxroll, Icy Veins). Pick how strictly an item must match to count as a completed slot."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Margin="0,0,0,10" />

                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="Format:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding FormatOptions}"
                              SelectedItem="{Binding SelectedFormatOption}"
                              DisplayMemberPath="Label" MinWidth="140" Margin="0,0,16,0" />
                    <TextBlock Text="Match:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding ThresholdOptions}"
                              SelectedItem="{Binding SelectedThresholdOption}"
                              DisplayMemberPath="Label" MinWidth="200" />
                </DockPanel>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="◀ Back" Height="28" Padding="14,0" Margin="0,0,8,0"
                            Command="{Binding BackToReviewCommand}" />
                    <Button Content="Generate ▶" Height="28" Padding="14,0"
                            Command="{Binding GenerateCommand}" />
                </StackPanel>

                <TextBox Text="{Binding PastedText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" AcceptsTab="False"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="12"
                         SpellCheck.IsEnabled="False"
                         VerticalContentAlignment="Top"
                         Padding="6" />
            </DockPanel>

            <!-- ══ Step 4 · Result ═════════════════════════════════════ -->
            <DockPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVis}, ConverterParameter=Result}">
                <TextBlock DockPanel.Dock="Top"
                           Text="Step 4 of 4 — Your progression filter"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock DockPanel.Dock="Top"
                           Text="Copy the share code and paste it into D4's loot filter menu, or open it in the editor to fine-tune."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Margin="0,0,0,10" />

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Copy Code" Height="28" Padding="14,0" Margin="0,0,8,0"
                            Command="{Binding CopyCodeCommand}" />
                    <Button Content="Open in Editor" Height="28" Padding="14,0" Margin="0,0,8,0"
                            Command="{Binding OpenInEditorCommand}" />
                    <Button Content="Start Over" Height="28" Padding="14,0"
                            Command="{Binding StartOverCommand}" />
                </StackPanel>

                <TextBox DockPanel.Dock="Top"
                         Text="{Binding ShareCode, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         MaxHeight="120"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="12"
                         Padding="6" Margin="0,0,0,10" />

                <Expander Header="Warnings" DockPanel.Dock="Top">
                    <ScrollViewer MaxHeight="140" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Warnings}" Padding="4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                               FontSize="11" Margin="0,1" Foreground="#B9770E" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Expander>
            </DockPanel>

        </Grid>
    </DockPanel>
</Window>
