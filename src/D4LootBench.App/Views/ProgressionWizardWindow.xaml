<Window x:Class="D4LootBench.App.Views.ProgressionWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:D4LootBench.App.Converters"
        xmlns:vm="clr-namespace:D4LootBench.App.ViewModels.Progression"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:ProgressionWizardViewModel, IsDesignTimeCreatable=False}"
        Title="Build a Progression Filter"
        Width="720" MinWidth="520"
        Height="560" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <conv:EnumEqualsVisibilityConverter x:Key="StepVis" />

        <!-- Red text when HasError, normal dark text otherwise -->
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasError}" Value="True">
                    <Setter Property="Foreground" Value="#C0392B" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasError}" Value="False">
                    <Setter Property="Foreground"
                            Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">

        <!-- ── Status bar ───────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Padding="0,10,0,0">
            <DockPanel>
                <!-- Active-profile indicator, shown on every step while a profile is open. -->
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding ActiveProfileName, StringFormat='Profile: {0}'}"
                           Opacity="0.7" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveProfileName}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding StatusText}"
                           Style="{StaticResource StatusTextStyle}"
                           TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <!-- ── Step panels (exactly one visible) ────────────────────── -->
        <Grid>

            <!-- ══ Step 0 · Profiles (home) ════════════════════════════ -->
            <DockPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVis}, ConverterParameter=Profiles}">
                <TextBlock DockPanel.Dock="Top"
                           Text="Profiles"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock DockPanel.Dock="Top"
                           Text="Open a saved profile, or start a new one."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Margin="0,0,0,10" />

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Start New" Height="28" Padding="14,0" Margin="0,0,8,0"
                            Command="{Binding StartNewProfileCommand}" />
                    <Button Content="Open" Height="28" Padding="14,0" IsDefault="True"
                            Command="{Binding OpenSelectedProfileCommand}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Width="140" Margin="10,0,0,0">
                    <Button Content="Duplicate" Height="28" Padding="8,0" Margin="0,0,0,6"
                            Command="{Binding DuplicateSelectedProfileCommand}" />
                    <Button Content="Delete" Height="28" Padding="8,0" Margin="0,0,0,6"
                            Command="{Binding DeleteSelectedProfileCommand}" />
                    <Separator Margin="0,4" />
                    <TextBlock Text="Rename to:" FontSize="11" Margin="0,0,0,2" />
                    <TextBox Text="{Binding RenameInput, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,6" />
                    <Button Content="Rename" Height="28" Padding="8,0"
                            Command="{Binding RenameSelectedProfileCommand}" />
                </StackPanel>

                <Border BorderThickness="1" Padding="4"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
                    <ListBox ItemsSource="{Binding Profiles}"
                             SelectedItem="{Binding SelectedProfile}"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick"
                                          Command="{Binding OpenSelectedProfileCommand}" />
                        </ListBox.InputBindings>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,2">
                                    <TextBlock Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold" />
                                    <TextBlock Opacity="0.7" FontSize="11">
                                        <Run Text="{Binding PlayerClass, Mode=OneWay}" /> ·
                                        <Run Text="{Binding Gear.Count, Mode=OneWay}" /> item(s) ·
                                        <Run Text="{Binding ModifiedUtc, Mode=OneWay, StringFormat='{}{0:g}'}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- ══ Step 1 · Read Gear ══════════════════════════════════ -->
            <DockPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVis}, ConverterParameter=ReadGear}">
                <TextBlock DockPanel.Dock="Top"
                           Text="Step 1 of 5 — Read your equipped gear"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock DockPanel.Dock="Top"
                           Text="Screenshot a gear tooltip in-game (Win+Shift+S), then paste it here — or open a saved image. Enable Advanced Tooltip Information in D4."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Margin="0,0,0,10" />

                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Paste Screenshot" Click="PasteScreenshot"
                            Height="28" Padding="12,0" Margin="0,0,8,0" />
                    <Button Content="Open Image…" Click="OpenImageFile"
                            Height="28" Padding="12,0" />
                </StackPanel>

                <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <Button Content="‹ Profiles"
                            HorizontalAlignment="Left"
                            Height="28" Padding="14,0"
                            Command="{Binding GoToProfilesCommand}" />
                    <Button Content="Next: Review ▶"
                            HorizontalAlignment="Right"
                            Height="28" Padding="14,0"
                            Command="{Binding NextToReviewCommand}" />
                </DockPanel>

                <Border BorderThickness="1" Padding="4"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
                    <ListBox ItemsSource="{Binding Items}"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Remove"
                                            Height="24" Padding="8,0"
                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="{Binding ItemTypeName, Mode=OneWay}" FontWeight="SemiBold" />
                                        <Run Text=" — " />
                                        <Run Text="{Binding Slot, Mode=OneWay}" />
                                    </TextBlock>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- ══ Step 2 · Review ═════════════════════════════════════ -->
            <DockPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVis}, ConverterParameter=Review}">
                <TextBlock DockPanel.Dock="Top"
                           Text="Step 2 of 5 — Review &amp; correct"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock DockPanel.Dock="Top"
                           Text="Fix any misread slot, power, rarity, or affix. Tick greater affixes by hand — OCR cannot detect them."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Margin="0,0,0,10" />

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="◀ Back" Height="28" Padding="14,0" Margin="0,0,8,0"
                            Command="{Binding BackToReadCommand}" />
                    <Button Content="Next: Goal ▶" Height="28" Padding="14,0"
                            Command="{Binding NextToGoalCommand}" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,8"
                                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ItemTypeName, Mode=OneWay}"
                                                   FontWeight="SemiBold" Margin="0,0,0,6" />

                                        <!-- Needs-review highlight -->
                                        <TextBlock Text="⚠ Needs review — check the fields below."
                                                   Foreground="#C0392B" Margin="0,0,0,6"
                                                   Visibility="{Binding NeedsReview, Converter={StaticResource StepVis}, ConverterParameter=True}" />

                                        <UniformGrid Columns="4" Margin="0,0,0,6">
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Slot" FontSize="11" />
                                                <ComboBox ItemsSource="{Binding AvailableSlots}"
                                                          SelectedItem="{Binding Slot}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Item Power" FontSize="11" />
                                                <TextBox Text="{Binding ItemPower, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Rarity" FontSize="11" />
                                                <ComboBox ItemsSource="{Binding AvailableRarities}"
                                                          SelectedItem="{Binding Rarity}" />
                                            </StackPanel>
                                            <StackPanel VerticalAlignment="Bottom">
                                                <CheckBox Content="Ancestral" IsChecked="{Binding IsAncestral}" />
                                            </StackPanel>
                                        </UniformGrid>

                                        <TextBlock Text="Affixes" FontSize="11" Margin="0,0,0,2" />
                                        <ItemsControl ItemsSource="{Binding Affixes}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel Margin="0,1">
                                                        <CheckBox DockPanel.Dock="Right" Content="Greater"
                                                                  VerticalAlignment="Center" Margin="8,0,0,0"
                                                                  IsChecked="{Binding IsGreaterAffix}" />
                                                        <TextBlock Text="{Binding RawText, Mode=OneWay}"
                                                                   TextWrapping="Wrap" VerticalAlignment="Center" />
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <ItemsControl ItemsSource="{Binding Warnings}" Margin="0,4,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                                               FontSize="11" Foreground="#B9770E" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <!-- ══ Step 3 · Goal ═══════════════════════════════════════ -->
            <DockPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVis}, ConverterParameter=Goal}">
                <TextBlock DockPanel.Dock="Top"
                           Text="Step 3 of 5 — Paste your goal build"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock DockPanel.Dock="Top"
                           Text="Paste the gear section of a build guide (Mobalytics, Maxroll, Icy Veins). The filter recolors any item that improves on your equipped gear; a slot drops out once your item already has every target affix."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Margin="0,0,0,10" />

                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="Format:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding FormatOptions}"
                              SelectedItem="{Binding SelectedFormatOption}"
                              DisplayMemberPath="Label" MinWidth="140" />
                    <TextBlock Text="Character class:" VerticalAlignment="Center" Margin="16,0,8,0" />
                    <ComboBox ItemsSource="{Binding Classes}"
                              SelectedItem="{Binding SelectedClass}"
                              MinWidth="140" />
                </DockPanel>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="◀ Back" Height="28" Padding="14,0" Margin="0,0,8,0"
                            Command="{Binding BackToReviewCommand}" />
                    <Button Content="Next: Static Rules ▶" Height="28" Padding="14,0"
                            Command="{Binding NextToStaticRulesCommand}" />
                </StackPanel>

                <TextBox Text="{Binding PastedText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" AcceptsTab="False"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="12"
                         SpellCheck.IsEnabled="False"
                         VerticalContentAlignment="Top"
                         Padding="6" />
            </DockPanel>

            <!-- ══ Step 4 · Static Rules ═══════════════════════════════ -->
            <DockPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVis}, ConverterParameter=StaticRules}">
                <TextBlock DockPanel.Dock="Top"
                           Text="Step 4 of 5 — Static rule blocks (optional)"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock DockPanel.Dock="Top"
                           Text="Wrap the generated better-gear rules with your own static rules. Override rules take priority over better-gear (e.g. always show mythic uniques); overridden-by rules sit below it, above the final catch-all (e.g. never show rares). Import each block from a filter share code on your clipboard, or skip this step to generate better-gear only."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Margin="0,0,0,10" />

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="◀ Back" Height="28" Padding="14,0" Margin="0,0,8,0"
                            Command="{Binding BackToGoalCommand}" />
                    <Button Content="Generate ▶" Height="28" Padding="14,0"
                            Command="{Binding GenerateCommand}" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Override block: takes priority OVER better-gear (placed first). -->
                        <Border BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,8"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
                            <StackPanel>
                                <TextBlock Text="Override block — takes priority over better-gear"
                                           FontWeight="SemiBold" Margin="0,0,0,2" />
                                <TextBlock Text="Placed above the better-gear rules. Example: always show mythic uniques."
                                           TextWrapping="Wrap" FontSize="11"
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                           Margin="0,0,0,6" />
                                <TextBlock Margin="0,0,0,6">
                                    <Run Text="Rules in this block: " />
                                    <Run Text="{Binding OverrideRuleCount, Mode=OneWay}" FontWeight="SemiBold" />
                                </TextBlock>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Import from clipboard" Height="28" Padding="12,0" Margin="0,0,8,0"
                                            Command="{Binding ImportOverrideBlockCommand}" />
                                    <Button Content="Clear" Height="28" Padding="12,0"
                                            Command="{Binding ClearOverrideBlockCommand}" />
                                    <Button Content="Edit…" Height="28" Padding="12,0" Margin="8,0,0,0"
                                            Command="{Binding EditOverrideBlockCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Overridden-by block: better-gear takes priority OVER these (placed below better-gear). -->
                        <Border BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,8"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
                            <StackPanel>
                                <TextBlock Text="Overridden-by block — better-gear takes priority over these"
                                           FontWeight="SemiBold" Margin="0,0,0,2" />
                                <TextBlock Text="Placed below the better-gear rules, above the final catch-all. Example: never show rares."
                                           TextWrapping="Wrap" FontSize="11"
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                           Margin="0,0,0,6" />
                                <TextBlock Margin="0,0,0,6">
                                    <Run Text="Rules in this block: " />
                                    <Run Text="{Binding OverriddenByRuleCount, Mode=OneWay}" FontWeight="SemiBold" />
                                </TextBlock>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Import from clipboard" Height="28" Padding="12,0" Margin="0,0,8,0"
                                            Command="{Binding ImportOverriddenByBlockCommand}" />
                                    <Button Content="Clear" Height="28" Padding="12,0"
                                            Command="{Binding ClearOverriddenByBlockCommand}" />
                                    <Button Content="Edit…" Height="28" Padding="12,0" Margin="8,0,0,0"
                                            Command="{Binding EditOverriddenByBlockCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>

            <!-- ══ Step 5 · Result ═════════════════════════════════════ -->
            <DockPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVis}, ConverterParameter=Result}">
                <TextBlock DockPanel.Dock="Top"
                           Text="Step 5 of 5 — Your progression filter"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock DockPanel.Dock="Top"
                           Text="Copy the share code and paste it into D4's loot filter menu, or open it in the editor to fine-tune."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Margin="0,0,0,10" />

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Copy Code" Height="28" Padding="14,0" Margin="0,0,8,0"
                            Command="{Binding CopyCodeCommand}" />
                    <Button Content="Open in Editor" Height="28" Padding="14,0" Margin="0,0,8,0"
                            Command="{Binding OpenInEditorCommand}" />
                    <Button Content="Start Over" Height="28" Padding="14,0"
                            Command="{Binding StartOverCommand}" />
                </StackPanel>

                <!-- Save-as row: creates a new profile from this session. Auto-save covers
                     an already-active profile, so this is for naming a fresh one. -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Save as profile:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Width="180" VerticalAlignment="Center"
                             Text="{Binding SaveAsName, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Save" Height="28" Padding="14,0" Margin="6,0,0,0"
                            Command="{Binding SaveAsProfileCommand}" />
                </StackPanel>

                <TextBox DockPanel.Dock="Top"
                         Text="{Binding ShareCode, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         MaxHeight="120"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="12"
                         Padding="6" Margin="0,0,0,10" />

                <Expander Header="Warnings" DockPanel.Dock="Top">
                    <ScrollViewer MaxHeight="140" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Warnings}" Padding="4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                               FontSize="11" Margin="0,1" Foreground="#B9770E" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Expander>
            </DockPanel>

        </Grid>
    </DockPanel>
</Window>
