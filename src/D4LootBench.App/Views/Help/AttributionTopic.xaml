<UserControl
    x:Class="D4LootBench.App.Views.Help.AttributionTopic"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d">

    <FlowDocumentScrollViewer>
        <FlowDocument FontFamily="Segoe UI" FontSize="13" PagePadding="20,16">

            <Paragraph FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12">
                Attribution
            </Paragraph>

            <Paragraph>
                D4LootBench was built on community reverse-engineering work. The following sources are
                gratefully credited:
            </Paragraph>

            <!-- WPF Grid in BlockUIContainer — FlowDocument Table has broken star-column layout -->
            <BlockUIContainer Margin="0,8,0,16">
                <Border BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Column="0" Grid.Row="0"
                                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                Padding="6,5">
                            <TextBlock Text="Source" FontWeight="SemiBold" />
                        </Border>
                        <Border Grid.Column="1" Grid.Row="0"
                                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1,0,1,0" Padding="6,5">
                            <TextBlock Text="License" FontWeight="SemiBold" />
                        </Border>
                        <Border Grid.Column="2" Grid.Row="0"
                                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                Padding="6,5">
                            <TextBlock Text="Contribution" FontWeight="SemiBold" />
                        </Border>

                        <!-- Row 1 — Upsilon72 -->
                        <Border Grid.Column="0" Grid.Row="1"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="0,1,0,0" Padding="6,5">
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/Upsilon72/d4-filter-generator"
                                           RequestNavigate="OnHyperlinkNavigate">
                                    Upsilon72/d4-filter-generator
                                </Hyperlink>
                            </TextBlock>
                        </Border>
                        <Border Grid.Column="1" Grid.Row="1"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1,1,1,0" Padding="6,5">
                            <TextBlock Text="MIT" />
                        </Border>
                        <Border Grid.Column="2" Grid.Row="1"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="0,1,0,0" Padding="6,5">
                            <TextBlock Text="Protobuf wire format reverse engineering; affix hash IDs; condition encoding"
                                       TextWrapping="Wrap" />
                        </Border>

                        <!-- Row 2 — fnuecke -->
                        <Border Grid.Column="0" Grid.Row="2"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="0,1,0,0" Padding="6,5">
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/fnuecke/diablo4-loot-filter-viewer"
                                           RequestNavigate="OnHyperlinkNavigate">
                                    fnuecke/diablo4-loot-filter-viewer
                                </Hyperlink>
                            </TextBlock>
                        </Border>
                        <Border Grid.Column="1" Grid.Row="2"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1,1,1,0" Padding="6,5">
                            <TextBlock Text="Unlicense" />
                        </Border>
                        <Border Grid.Column="2" Grid.Row="2"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="0,1,0,0" Padding="6,5">
                            <TextBlock Text="Complete .proto field layout; condition type semantics; ID lookup table"
                                       TextWrapping="Wrap" />
                        </Border>

                        <!-- Row 3 — DiabloTools -->
                        <Border Grid.Column="0" Grid.Row="3"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="0,1,0,0" Padding="6,5">
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/DiabloTools/d4data"
                                           RequestNavigate="OnHyperlinkNavigate">
                                    DiabloTools/d4data
                                </Hyperlink>
                            </TextBlock>
                        </Border>
                        <Border Grid.Column="1" Grid.Row="3"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1,1,1,0" Padding="6,5">
                            <TextBlock Text="MIT" />
                        </Border>
                        <Border Grid.Column="2" Grid.Row="3"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="0,1,0,0" Padding="6,5">
                            <TextBlock Text="Datamined ID tables for skills, item types, and affixes; unique item display names"
                                       TextWrapping="Wrap" />
                        </Border>

                        <!-- Row 4 — d4lfteam -->
                        <Border Grid.Column="0" Grid.Row="4"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="0,1,0,0" Padding="6,5">
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/d4lfteam/d4lf"
                                           RequestNavigate="OnHyperlinkNavigate">
                                    d4lfteam/d4lf
                                </Hyperlink>
                            </TextBlock>
                        </Border>
                        <Border Grid.Column="1" Grid.Row="4"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1,1,1,0" Padding="6,5">
                            <TextBlock Text="MIT" />
                        </Border>
                        <Border Grid.Column="2" Grid.Row="4"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="0,1,0,0" Padding="6,5">
                            <TextBlock Text="Affix name reference database"
                                       TextWrapping="Wrap" />
                        </Border>

                        <!-- Row 5 — Raxx -->
                        <Border Grid.Column="0" Grid.Row="5"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="0,1,0,0" Padding="6,5">
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/raxxanterax/GAMING/blob/main/Raxxs%20Diablo%204%20T6%2B%20Endgame%20Filter.txt"
                                           RequestNavigate="OnHyperlinkNavigate">
                                    Raxx (filter author)
                                </Hyperlink>
                            </TextBlock>
                        </Border>
                        <Border Grid.Column="1" Grid.Row="5"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1,1,1,0" Padding="6,5">
                            <TextBlock Text="N/A" />
                        </Border>
                        <Border Grid.Column="2" Grid.Row="5"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="0,1,0,0" Padding="6,5">
                            <TextBlock Text="Real-world filter export used to validate the format spec"
                                       TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                </Border>
            </BlockUIContainer>

        </FlowDocument>
    </FlowDocumentScrollViewer>

</UserControl>
