<UserControl
    x:Class="D4LootBench.App.Views.Help.AiSetupTopic"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d">

    <FlowDocumentScrollViewer>
        <FlowDocument FontFamily="Segoe UI" FontSize="13" PagePadding="20,16">

            <Paragraph FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12">
                AI Assistant Setup
            </Paragraph>

            <Paragraph>
                The AI assistant is optional — D4LootBench works fully without it. When configured, you
                can describe a rule in plain English and the assistant will generate it for you.
            </Paragraph>

            <Paragraph FontSize="14" FontWeight="SemiBold" Margin="0,12,0,6">
                Step 1 — Install Ollama
            </Paragraph>

            <Paragraph>
                Download and install Ollama from
                <Hyperlink NavigateUri="https://ollama.com" RequestNavigate="OnHyperlinkNavigate">
                    ollama.com
                </Hyperlink>.
                Ollama runs language models locally on your machine — no account or API key required.
            </Paragraph>

            <Paragraph FontSize="14" FontWeight="SemiBold" Margin="0,12,0,6">
                Step 2 — Pull a model
            </Paragraph>

            <Paragraph>
                Open a terminal and run one of the following commands based on your GPU:
            </Paragraph>

            <!-- WPF Grid in BlockUIContainer — FlowDocument Table has broken star-column layout -->
            <BlockUIContainer Margin="0,4,0,12">
                <Border BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Column="0" Grid.Row="0"
                                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                Padding="6,5">
                            <TextBlock Text="GPU VRAM" FontWeight="SemiBold" />
                        </Border>
                        <Border Grid.Column="1" Grid.Row="0"
                                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1,0,1,0" Padding="6,5">
                            <TextBlock Text="Command" FontWeight="SemiBold" />
                        </Border>
                        <Border Grid.Column="2" Grid.Row="0"
                                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                Padding="6,5">
                            <TextBlock Text="Notes" FontWeight="SemiBold" />
                        </Border>

                        <!-- Row 1 -->
                        <Border Grid.Column="0" Grid.Row="1"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="0,1,0,0" Padding="6,5">
                            <TextBlock Text="10 GB+" />
                        </Border>
                        <Border Grid.Column="1" Grid.Row="1"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1,1,1,0" Padding="6,5">
                            <TextBlock Text="ollama pull qwen2.5-coder:14b" FontFamily="Consolas" />
                        </Border>
                        <Border Grid.Column="2" Grid.Row="1"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="0,1,0,0" Padding="6,5">
                            <TextBlock Text="Best quality" TextWrapping="Wrap" />
                        </Border>

                        <!-- Row 2 -->
                        <Border Grid.Column="0" Grid.Row="2"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="0,1,0,0" Padding="6,5">
                            <TextBlock Text="6–9 GB" />
                        </Border>
                        <Border Grid.Column="1" Grid.Row="2"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1,1,1,0" Padding="6,5">
                            <TextBlock Text="ollama pull qwen2.5-coder:7b" FontFamily="Consolas" />
                        </Border>
                        <Border Grid.Column="2" Grid.Row="2"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="0,1,0,0" Padding="6,5">
                            <TextBlock Text="Good quality; fits mid-range GPUs" TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                </Border>
            </BlockUIContainer>

            <Paragraph>
                If you're unsure how much VRAM your GPU has, check <Bold>Task Manager → Performance → GPU</Bold>.
                If a model is too large for your VRAM, Ollama falls back to CPU — inference will work but
                will be significantly slower.
            </Paragraph>

            <Paragraph>
                <Bold>Non-coding general-purpose models are not recommended.</Bold> The assistant output is
                structured JSON with a strict schema — models like <Run FontFamily="Consolas">llama3.2</Run>
                tested poorly. Use a coder model.
            </Paragraph>

            <Paragraph FontSize="14" FontWeight="SemiBold" Margin="0,12,0,6">
                Step 3 — Configure D4LootBench
            </Paragraph>

            <Paragraph>
                Click the <Bold>AI Assistant</Bold> button in the toolbar to expand the panel. In the panel:
            </Paragraph>

            <List Margin="8,4,0,0">
                <ListItem><Paragraph>Set <Bold>Base URL</Bold> to <Run FontFamily="Consolas">http://localhost:11434</Run></Paragraph></ListItem>
                <ListItem><Paragraph>Set <Bold>Model</Bold> to the model name you pulled (e.g. <Run FontFamily="Consolas">qwen2.5-coder:14b</Run>)</Paragraph></ListItem>
            </List>

        </FlowDocument>
    </FlowDocumentScrollViewer>

</UserControl>
