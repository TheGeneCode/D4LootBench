<Window x:Class="D4LootBench.App.Views.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Color Picker"
        Width="368" Height="454"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- hex + preview -->
            <RowDefinition Height="12" />     <!-- gap -->
            <RowDefinition Height="280" />    <!-- pickers -->
            <RowDefinition Height="12" />     <!-- gap -->
            <RowDefinition Height="Auto" />   <!-- buttons -->
        </Grid.RowDefinitions>

        <!-- ── Header: hex input + preview ──────────────────────────── -->
        <DockPanel Grid.Row="0">
            <Ellipse Width="44" Height="44"
                     Fill="{Binding PreviewBrush}"
                     Stroke="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                     StrokeThickness="1"
                     DockPanel.Dock="Right" Margin="10,0,0,0" />
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="#"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="15"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0" />
                <TextBox x:Name="HexTextBox"
                         Text="{Binding HexText, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="15"
                         MaxLength="6"
                         Width="84"
                         VerticalContentAlignment="Center"
                         KeyDown="HexTextBox_KeyDown" />
            </StackPanel>
        </DockPanel>

        <!-- ── Main row: SV canvas + hue slider ─────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="22" />
            </Grid.ColumnDefinitions>

            <!-- SV gradient + cursor -->
            <Grid Grid.Column="0" x:Name="SvGrid">
                <!-- White → HueColor horizontal base -->
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="White" Offset="0" />
                            <GradientStop x:Name="HueGradientStop" Color="Red" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- Transparent → Black vertical overlay -->
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0" />
                            <GradientStop Color="Black" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- Cursor canvas — receives mouse input -->
                <Canvas x:Name="SvCanvas"
                        Background="Transparent"
                        Cursor="Cross"
                        MouseLeftButtonDown="SvCanvas_MouseLeftButtonDown"
                        MouseMove="SvCanvas_MouseMove"
                        MouseLeftButtonUp="SvCanvas_MouseLeftButtonUp">
                    <Ellipse x:Name="SvCursor"
                             Width="14" Height="14"
                             Stroke="White" StrokeThickness="2"
                             IsHitTestVisible="False">
                        <Ellipse.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="3" Color="Black" Opacity="0.8" />
                        </Ellipse.Effect>
                    </Ellipse>
                </Canvas>
            </Grid>

            <!-- Hue slider + cursor -->
            <Grid Grid.Column="2" x:Name="HueGrid">
                <!-- Rainbow hue track -->
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FF0000" Offset="0" />
                            <GradientStop Color="#FFFF00" Offset="0.167" />
                            <GradientStop Color="#00FF00" Offset="0.333" />
                            <GradientStop Color="#00FFFF" Offset="0.5" />
                            <GradientStop Color="#0000FF" Offset="0.667" />
                            <GradientStop Color="#FF00FF" Offset="0.833" />
                            <GradientStop Color="#FF0000" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- Cursor canvas -->
                <Canvas x:Name="HueCanvas"
                        Background="Transparent"
                        Cursor="Hand"
                        MouseLeftButtonDown="HueCanvas_MouseLeftButtonDown"
                        MouseMove="HueCanvas_MouseMove"
                        MouseLeftButtonUp="HueCanvas_MouseLeftButtonUp">
                    <Rectangle x:Name="HueCursor"
                               Width="28" Height="4"
                               Fill="White" StrokeThickness="0.5"
                               Stroke="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                               Canvas.Left="-3"
                               IsHitTestVisible="False">
                        <Rectangle.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="3" Color="Black" Opacity="0.8" />
                        </Rectangle.Effect>
                    </Rectangle>
                </Canvas>
            </Grid>
        </Grid>

        <!-- ── Buttons ───────────────────────────────────────────────── -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Accept"
                    Width="90" Height="30"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Accept_Click" />
            <Button Content="Cancel"
                    Width="90" Height="30"
                    IsCancel="True"
                    Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
