<Window
    x:Class="D4LootBench.App.Views.RawEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:D4LootBench.App.ViewModels"
    xmlns:views="clr-namespace:D4LootBench.App.Views"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:RawEditorViewModel, IsDesignTimeCreatable=False}"
    Title="Raw Editor"
    Width="900" Height="650"
    MinWidth="600" MinHeight="400"
    WindowStartupLocation="CenterOwner">

    <Window.Resources />

    <DockPanel>
        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top" ToolBarTray.IsLocked="True">
            <Button Content="Validate"
                    Command="{Binding ValidateCommand}"
                    ToolTip="Parse JSON and check against game-enforced rules — does not modify the visual editor"
                    Padding="10,2" />
            <Button Content="Apply"
                    Command="{Binding ApplyCommand}"
                    ToolTip="Parse JSON, validate, and apply to the visual editor"
                    Padding="10,2" FontWeight="SemiBold" />
            <Separator />
            <Button Content="Close"
                    Click="OnCloseClick"
                    Padding="8,2" />
        </ToolBar>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                    <Setter Property="Foreground" Value="Red" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- Issues panel (collapsed when empty) -->
        <views:IssuesPanel DockPanel.Dock="Bottom" Issues="{Binding Issues}">
            <views:IssuesPanel.Style>
                <Style TargetType="views:IssuesPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Issues.Count}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding HasError}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </views:IssuesPanel.Style>
        </views:IssuesPanel>

        <!-- Editor -->
        <avalonEdit:TextEditor
            x:Name="Editor"
            SyntaxHighlighting="JavaScript"
            FontFamily="Cascadia Code, Consolas, Courier New"
            FontSize="13"
            ShowLineNumbers="True"
            WordWrap="False"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto" />
    </DockPanel>
</Window>
