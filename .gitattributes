# Normalize line endings. This repo is Windows/.NET only and the formatter
# (dotnet format / StyleCop) enforces CRLF, so pin source files to CRLF in the
# working tree to stop LF↔CRLF churn regardless of the editor/tool that wrote them.

# Default: let Git detect text vs binary; check out text as CRLF.
* text=auto eol=crlf

# Source / project / doc files — always CRLF.
*.cs        text eol=crlf
*.csproj    text eol=crlf
*.props     text eol=crlf
*.targets   text eol=crlf
*.slnx      text eol=crlf
*.sln       text eol=crlf
*.xaml      text eol=crlf
*.json      text eol=crlf
*.md        text eol=crlf
*.yml       text eol=crlf
*.yaml      text eol=crlf
*.editorconfig text eol=crlf
*.ps1       text eol=crlf

# Shell scripts must stay LF or they break under bash.
*.sh        text eol=lf

# Binary assets — never touch.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.exe       binary
*.dll       binary
*.pdb       binary
*.zip       binary
